# ─────────────────────────────────────────────────────────────────────────────
# HypeReels Quorra Python Worker Environment
# Deployed at: /mnt/cache/appdata/hypereels/.env.workers on Quorra (192.168.1.100)
#
# Copy to .env.workers and fill in real values.
# Never commit .env.workers to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL (Quorra Docker hypereels-postgres, 192.168.1.100:7432) ────────
# Password only — host/DB/user are hardcoded in docker-compose.workers.yml
# The hypereels-postgres container runs on Quorra at host port 7432.
POSTGRES_PASSWORD=

# ─── Redis (Case CT 114, 192.168.1.137:6379) ──────────────────────────────────
# Password set via requirepass in redis.conf on CT 114
REDIS_PASSWORD=

# ─── MinIO (Case CT 115, 192.168.1.138:9000) ──────────────────────────────────
# Create a dedicated MinIO service account with least-privilege (read/write
# on the hypereels bucket only). Do not use the MinIO root credentials here.
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# ─── MinIO connection (do not change unless CT 115 IP changes) ────────────────
MINIO_ENDPOINT=http://192.168.1.138:9000
MINIO_BUCKET=hypereels

# ─── InsightFace (person detection worker) ────────────────────────────────────
# Model pack to use. buffalo_l provides best accuracy for cross-clip clustering.
# buffalo_s is faster but less accurate — not recommended for MVP.
INSIGHTFACE_MODEL=buffalo_l

# Cosine similarity threshold for cross-clip person identity matching.
# Same-person ArcFace pairs typically score 0.4-0.7.
# 0.45 minimises false merges while tolerating lighting/angle variation.
INSIGHTFACE_COSINE_THRESHOLD=0.45

# ─── FFmpeg (assembly worker) ─────────────────────────────────────────────────
# CRF: 18 (visually lossless) to 28 (smaller file). 20 is a good default.
FFMPEG_CRF=20

# Preset: ultrafast | superfast | veryfast | faster | fast | medium | slow
# fast is a good balance of speed and compression for 1080p on Quorra's CPU.
FFMPEG_PRESET=fast

# ─── Python worker HTTP server ────────────────────────────────────────────────
# Port the health/admin HTTP server listens on inside the detection container.
PYTHON_WORKER_PORT=8000

# Number of uvicorn worker processes for the HTTP server.
PYTHON_WORKER_WORKERS=2
