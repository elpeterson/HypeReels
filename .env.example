# ─────────────────────────────────────────────────────────────────────────────
# HypeReels Environment Variables
# Copy this file to .env and fill in real values before running locally.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────

# Full PostgreSQL connection string.
# Local dev: use docker-compose postgres service (no SSL).
# Production (Quorra Docker hypereels-postgres, port 7432): postgresql://hypereels:<password>@192.168.1.100:7432/hypereels
DATABASE_URL=postgresql://hypereels:hypereels@localhost:5432/hypereels?sslmode=disable

# Set to "false" to disable TLS certificate verification (local dev only).
# Leave unset in production (defaults to require-ssl).
DATABASE_SSL=false

# ─── Redis ────────────────────────────────────────────────────────────────────

# Redis connection URL used by BullMQ queues and SSE pub/sub.
# Local dev: redis://localhost:6379
# Production (Proxmox CT 114): redis://192.168.1.137:6379
REDIS_URL=redis://localhost:6379

# ─── MinIO (self-hosted object storage) ───────────────────────────────────────

# MinIO S3-compatible API endpoint.
# Local dev (docker-compose): http://localhost:9000
# Production (Proxmox CT 115, storage_1tb ZFS pool): http://192.168.1.138:9000
MINIO_ENDPOINT=http://localhost:9000

# MinIO access credentials.
# For local dev, use the MinIO root credentials set in docker-compose.yml.
# For production, create a dedicated MinIO service account with least-privilege.
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin

# Name of the MinIO bucket that stores all HypeReels assets.
MINIO_BUCKET=hypereels

# Public base URL for assets that should be browser-accessible (thumbnails, waveforms).
# Local dev: http://localhost:9000/hypereels
# Production: http://192.168.1.138:9000/hypereels (CT 115 direct LAN IP, storage_1tb pool)
MINIO_PUBLIC_URL=http://localhost:9000/hypereels

# Legacy aliases — kept for docker-compose compatibility during migration.
# Remove these once docker-compose.yml is updated to use MINIO_* names.
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=hypereels
R2_PUBLIC_URL=http://localhost:9000/hypereels

# ─── Prometheus metrics ───────────────────────────────────────────────────────

# Path at which prom-client exposes metrics for the Prometheus scraper.
# Existing Prometheus on Quorra (192.168.1.100) scrapes this endpoint.
METRICS_PATH=/metrics

# ─── Session lifecycle ────────────────────────────────────────────────────────

# How many hours an idle (no completed download) session lives before auto-purge.
# Stale session sweep runs on a BullMQ repeatable job.
SESSION_TTL_HOURS=24

# How many minutes after download-initiated before cleanup fires.
# Gives the browser time to complete the download before assets are deleted.
CLEANUP_GRACE_PERIOD_MINUTES=5

# ─── API server ───────────────────────────────────────────────────────────────

# Port the Fastify HTTP server listens on.
PORT=3001

# Bind address. Use 0.0.0.0 inside Docker/LXC, 127.0.0.1 for local-only.
HOST=0.0.0.0

# Node environment. Controls log format (pretty in dev, JSON in production)
# and error message verbosity.
# Values: development | production | test
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Allowed CORS origin for the frontend.
# Local dev: http://localhost:5173 (Vite default port)
# Production: your actual frontend domain, e.g. https://hypereels.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# ─── Python workers ───────────────────────────────────────────────────────────

# Base URL of the Python worker HTTP service (InsightFace person detection,
# librosa audio analysis, FFmpeg assembly).
# Local dev (docker-compose): http://python-workers:8000
# Production (Quorra Docker): http://192.168.1.100:8000
PYTHON_WORKER_URL=http://localhost:8000

# Maximum milliseconds to wait for a Python worker response before timing out.
# Person detection (InsightFace CPU-only): 120000 (2 min) — default
# Audio analysis: 300000 (5 min)
# Assembly: 900000 (15 min) — overridden per-worker in code
PYTHON_TIMEOUT_MS=300000

# Per-worker timeout overrides (override the global PYTHON_TIMEOUT_MS for specific workers)
PYTHON_WORKER_AUDIO_TIMEOUT_MS=300000    # 5 minutes for audio analysis
PYTHON_WORKER_ASSEMBLY_TIMEOUT_MS=900000 # 15 minutes for assembly

# ─── Session & upload limits ──────────────────────────────────────────────────

# Maximum number of clips a single session can upload.
MAX_CLIPS_PER_SESSION=10

# Maximum duration (in milliseconds) for a single video clip.
MAX_CLIP_DURATION_MS=300000       # 5 minutes per clip

# Maximum file size (in bytes) for a single video clip.
MAX_CLIP_SIZE_BYTES=500000000     # 500 MB per clip

# Maximum duration (in milliseconds) for the audio track.
MAX_AUDIO_DURATION_MS=600000      # 10 minutes

# ─── Timeouts ─────────────────────────────────────────────────────────────────

# Maximum time (in milliseconds) for the full reel assembly job.
GENERATION_TIMEOUT_MS=900000      # 15 minutes

# ─── InsightFace (Python worker — person detection) ───────────────────────────

# InsightFace model pack name. buffalo_l is recommended for best accuracy.
INSIGHTFACE_MODEL=buffalo_l

# Cosine similarity threshold for cross-clip person clustering.
# Faces with similarity >= this value are considered the same person.
# 0.45 is the recommended value for ArcFace embeddings (see architecture.md ADR-003).
INSIGHTFACE_COSINE_THRESHOLD=0.45

# ─── FFmpeg encoding (Python assembly worker) ─────────────────────────────────

# Constant Rate Factor: 0 (lossless) – 51 (worst quality). 20 is visually transparent.
FFMPEG_CRF=20

# x264 encoding speed preset. Faster presets = larger files. 'fast' balances quality/speed.
FFMPEG_PRESET=fast

# Maximum output width in pixels. Output is scaled down if source is wider.
# -2 ensures height is divisible by 2 (required by yuv420p).
FFMPEG_MAX_WIDTH=1920

# ─── Redis auth ───────────────────────────────────────────────────────────────

# Redis password (must match 'requirepass' in redis.conf on production Redis LXC CT 114).
# Leave blank for local dev (no auth). Set a strong password in production.
REDIS_PASSWORD=

# ─── SPA static file serving ──────────────────────────────────────────────────

# Absolute path to the pre-built React SPA (Vite output).
# Leave empty in development — Vite dev server runs separately on :5173.
# In production, build and copy first:
#   cd <repo-root> && VITE_API_URL="" npm run build && cp -r dist/ server/client-dist/
# Then set this to the absolute path of client-dist/, or leave empty to use the default
# (server/client-dist/ relative to the server process cwd).
CLIENT_DIST_PATH=

# ─── Metrics ──────────────────────────────────────────────────────────────────

# URL path at which prom-client exposes metrics for the Prometheus scraper.
# Existing Prometheus on Quorra (192.168.1.100) scrapes this endpoint.
METRICS_PATH=/metrics
